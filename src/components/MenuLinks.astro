---
// Canonical site navigation. Used by both the standalone `/menu` page
// (works without JS) and the BaseLayout dialog (progressive enhancement
// on every page). One source of truth for the link list.
//
// Two discovery sources, merged at build time:
//
//  1. Astro pages that export a `menu: MenuMeta` constant from their
//     frontmatter — pages opt themselves into the menu without anyone
//     touching this file. See src/lib/menu.ts for the schema.
//  2. Farfield — publications are fetched live so the menu stays in
//     sync with whatever collections exist upstream.
//
// Static-only entries that aren't real Astro pages (the home link, the
// RSS feed) are added manually at the top of `compose()` below.

import { getLiveCollection } from "astro:content";
import { GROUP_ORDER, type MenuMeta } from "@lib/menu";

interface Link {
    href: string;
    label: string;
    order: number;
}
interface Group {
    label?: string;
    links: Link[];
}

/* ── 1. discover Astro pages with menu frontmatter ─────────────────── */

interface PageModule {
    menu?: MenuMeta;
}
const pageModules = import.meta.glob<PageModule>("/src/pages/**/*.astro", {
    eager: true,
});

/** Convert `/src/pages/foo/index.astro` → `/foo`, skip dynamic routes. */
function pathToHref(path: string): string | null {
    if (path.includes("[")) return null;
    const stripped = path
        .replace(/^\/src\/pages/, "")
        .replace(/\/index\.astro$/, "")
        .replace(/\.astro$/, "");
    return stripped || "/";
}

/** Default label = last URL segment with hyphens turned into spaces. */
function deriveLabel(href: string): string {
    if (href === "/") return "home";
    const last = href.split("/").filter(Boolean).pop() ?? "";
    return last.replace(/-/g, " ");
}

const fromPages: { meta: MenuMeta; href: string }[] = [];
for (const [path, mod] of Object.entries(pageModules)) {
    if (!mod.menu) continue;
    const href = mod.menu.href ?? pathToHref(path);
    if (!href) continue;
    fromPages.push({ meta: mod.menu, href });
}

/* ── 2. publications from Farfield (live collection) ──────────────── */

let publicationLinks: Link[] = [];
// Publications come from `/api/collections` (metadata, includes
// drafts in `entryCount`). To advertise only collections with public
// content, intersect against the documents collection — that endpoint
// returns published entries only. Empty collections (like melange
// while drafts cook) drop out of the menu but their routes still
// work for direct visits.
const [pubResult, docResult] = await Promise.all([
    getLiveCollection("publications"),
    getLiveCollection("documents"),
]);
if (pubResult.error) {
    console.error(
        "[MenuLinks] Farfield publications fetch failed:",
        pubResult.error,
    );
} else {
    const publishedSlugs = new Set(
        (docResult.entries ?? []).map(
            (e: { data: { collection: string } }) => e.data.collection,
        ),
    );
    // Fall back to the metadata's entryCount if the documents fetch
    // errored — better to over-advertise than to silently empty the
    // menu on a transient upstream blip.
    const hasContent = (slug: string, count: number | undefined): boolean => {
        if (docResult.error) {
            return typeof count !== "number" || count > 0;
        }
        return publishedSlugs.has(slug);
    };
    publicationLinks = pubResult.entries
        .filter((p) => hasContent(p.data.slug, p.data.entryCount))
        .map((p, i) => ({
            href: `/${p.data.slug}`,
            label: p.data.name.toLowerCase(),
            order: i,
        }));
}

/* ── compose ───────────────────────────────────────────────────────── */

const groupMap = new Map<string, Link[]>();

// Home link is the implicit top entry — not a frontmatter export
// because the homepage's frontmatter is busy with hero + feed logic.
groupMap.set("", [{ href: "/", label: "home", order: 0 }]);

// Pages with frontmatter
for (const p of fromPages) {
    const group = p.meta.group;
    const link: Link = {
        href: p.href,
        label: p.meta.label ?? deriveLabel(p.href),
        order: p.meta.order ?? 0,
    };
    if (!groupMap.has(group)) groupMap.set(group, []);
    groupMap.get(group)!.push(link);
}

// Farfield publications under "publications"
if (publicationLinks.length > 0) {
    if (!groupMap.has("publications")) groupMap.set("publications", []);
    groupMap.get("publications")!.push(...publicationLinks);
}

// RSS isn't an Astro page — it's generated by a route handler. Add manually.
const otherGroup = groupMap.get("other") ?? [];
otherGroup.push({ href: "/rss.xml", label: "rss", order: 99 });
groupMap.set("other", otherGroup);

// Sort within each group by `order`, then alpha by label.
for (const links of groupMap.values()) {
    links.sort((a, b) => a.order - b.order || a.label.localeCompare(b.label));
}

// Render groups in fixed canonical order, with any unknown groups
// (e.g. ones added later via frontmatter) appended alphabetically.
const knownGroups = new Set(GROUP_ORDER);
const orderedGroupKeys = [
    ...GROUP_ORDER.filter((g) => groupMap.has(g)),
    ...[...groupMap.keys()]
        .filter((g) => !knownGroups.has(g))
        .sort((a, b) => a.localeCompare(b)),
];

const groups: Group[] = orderedGroupKeys
    .map((key) => ({
        label: key || undefined,
        links: groupMap.get(key) ?? [],
    }))
    .filter((g) => g.links.length > 0);
---

<nav class="menu-links" aria-label="Site navigation">
    {groups.map((group) => (
        <section>
            {group.label && <h2>{group.label}</h2>}
            <ul>
                {group.links.map((link) => (
                    <li>
                        <a href={link.href}>{link.label}</a>
                    </li>
                ))}
            </ul>
        </section>
    ))}
</nav>

<style>
    .menu-links {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .menu-links section {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .menu-links h2 {
        font-family: var(--font-serif);
        font-style: italic;
        font-weight: var(--fw-normal);
        font-size: var(--fs-sm);
        color: var(--color-muted);
        text-transform: lowercase;
    }

    .menu-links ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-1);
    }

    .menu-links li {
        list-style: none;
    }

    .menu-links a {
        font-family: var(--font-serif);
        font-size: var(--fs-xl);
        text-decoration: none;
        color: inherit;
    }

    .menu-links a:hover {
        text-decoration: underline;
        text-decoration-thickness: 1px;
        text-underline-offset: 0.15em;
    }
</style>
