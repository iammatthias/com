---
// Header azulejo tile — one of the 100 pre-rendered snapshots
// (worker-og/azulejo, mirrored into public/azulejo) instead of the
// live WebGL AzulejoTile island. The island pulled React + three.js
// (~250KB gz) onto every page for a 32px decorative element; a 13KB
// JPG reads identically at this size. The inline script picks a
// random tile per load to keep the per-visit variance; <noscript>
// pins a fixed tile. The 45° rotation turns the square into a diamond.
---

<span class="header-tile">
    <img
        id="header-azulejo"
        width="32"
        height="32"
        alt="iammatthias"
        decoding="async"
    />
    <script is:inline>
        {
            const n = String(1 + Math.floor(Math.random() * 100)).padStart(
                3,
                "0",
            );
            document.getElementById("header-azulejo").src =
                "/azulejo/" + n + ".jpg";
        }
    </script>
    <noscript>
        <img
            src="/azulejo/001.jpg"
            width="32"
            height="32"
            alt="iammatthias"
        />
    </noscript>
</span>

<style>
    /* Fixed footprint + placeholder: the slot is 32×32 in layout flow
       regardless of image load state, so the header doesn't reflow
       while the tile fetches. The rotation makes the tile read as a
       diamond.

       Background uses the warm beige border token rather than
       --color-fg, so the placeholder reads as a gentle diamond hint
       instead of flashing solid near-black before the image paints. */
    .header-tile {
        display: inline-block;
        width: 32px;
        height: 32px;
        background: var(--color-border);
        transform: rotate(45deg);
        transform-origin: center;
        overflow: hidden;
    }

    .header-tile img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }
</style>
