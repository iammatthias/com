---
import BaseLayout from "../layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="That page doesn't exist." noindex>
    <article class="not-found">
        <p class="kind">404</p>
        <h1>Not found</h1>
        <p>That page doesn't exist — or it moved during the redesign.</p>
        <p>
            Try the <a href="/">homepage</a>, browse the <a href="/posts">posts</a>,
            <a href="/recipes">recipes</a>, <a href="/art">art</a>, or
            <a href="/open-source">open source</a> archives, or wander the
            <a href="/tags">tag index</a>.
        </p>
    </article>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        max-width: 60ch;
    }

    .kind {
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-muted);
    }

    .not-found h1 {
        font-family: var(--font-serif);
    }

    .not-found p {
        line-height: var(--lh-relaxed);
        text-wrap: pretty;
    }
</style>
