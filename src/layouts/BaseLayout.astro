---
import "../styles/globals.css";
import MenuLinks from "../components/MenuLinks.astro";
import Breadcrumbs, {
    type BreadcrumbItem,
} from "../components/Breadcrumbs.astro";
import { isPreview } from "@lib/preview";
import "@fontsource/metamorphous";
import metamorphousWoff2 from "@fontsource/metamorphous/files/metamorphous-latin-400-normal.woff2?url";

interface Props {
    /** Page-specific title. Site name is appended automatically. */
    title?: string;
    /** Page-specific meta description. */
    description?: string;
    /**
     * Path on the og worker (https://og.iammatthias.com). Defaults to "/"
     * which renders the homepage card. Pass an absolute URL to override
     * with an arbitrary image.
     */
    ogImage?: string;
    /** og:type. Default "website"; use "article" for posts. */
    ogType?: "website" | "article";
    /** Override canonical URL. Defaults to current pathname under Astro.site. */
    canonical?: string | URL;
    /** Emit robots: noindex,nofollow. */
    noindex?: boolean;
    /**
     * Breadcrumb trail rendered above the main content. Last item should
     * have no `href` (current page). The brand link in the header is the
     * implicit home, so this trail starts at the first sub-section.
     */
    breadcrumbs?: BreadcrumbItem[];
}

const SITE_NAME = "iammatthias";
const SITE_URL = "https://iammatthias.com";
const DEFAULT_DESCRIPTION = "Personal site of Matthias Jordan";

const {
    title,
    description = DEFAULT_DESCRIPTION,
    ogImage = "/",
    ogType = "website",
    canonical,
    noindex = false,
    breadcrumbs = [],
} = Astro.props;

// `siteOrigin` is intentionally derived from `Astro.site` (set in
// astro.config.mjs to https://iammatthias.com), NOT from the request
// host. The site is served on multiple hostnames (iammatthias.com +
// iam.casa) but every emitted URL — rel="canonical", og:url,
// twitter:url, sitemap entries, RSS <link> items — collapses to a
// single canonical origin so search engines and social platforms
// consolidate all authority on iammatthias.com. Don't replace this
// with `Astro.url.origin` or anything host-aware: that would split
// SEO juice across both hostnames.
const siteOrigin = Astro.site?.toString() ?? SITE_URL;
const canonicalURL = canonical
    ? new URL(canonical, siteOrigin)
    : new URL(Astro.url.pathname, siteOrigin);

const isAbsolute = /^https?:\/\//i.test(ogImage);
const ogOrigin = import.meta.env.DEV
    ? "http://localhost:8787"
    : "https://og.iammatthias.com";
const ogImageURL = isAbsolute ? new URL(ogImage) : new URL(ogImage, ogOrigin);

const fullTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;
const ogTitle = title ?? SITE_NAME;

// Draft-preview mode (dev only). When on, the whole site shows
// unpublished Farfield drafts; the banner below makes that obvious and
// offers a one-click exit. `isPreview` is always false in production.
const previewMode = isPreview(Astro);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="color-scheme" content="light dark" />
        <!-- Theme color matches the warm cream / warm near-black bg
             tokens in globals.css so the browser chrome blends with
             the page rather than flashing pure white/black at load. -->
        <meta
            name="theme-color"
            content="#f1ebdc"
            media="(prefers-color-scheme: light)"
        />
        <meta
            name="theme-color"
            content="#1c1a16"
            media="(prefers-color-scheme: dark)"
        />

        <title>{fullTitle}</title>
        <meta name="description" content={description} />
        <link rel="canonical" href={canonicalURL} />
        {noindex && <meta name="robots" content="noindex,nofollow" />}

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Metamorphous is the serif used for all headings; preloading
             the latin woff2 keeps the swap window short on first visit.
             Same hashed asset the @fontsource CSS resolves to, so this
             never double-downloads. -->
        <link
            rel="preload"
            as="font"
            type="font/woff2"
            href={metamorphousWoff2}
            crossorigin
        />

        <!-- Open Graph -->
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={ogTitle} />

        <!-- Twitter -->
        <meta name="twitter:card" content="summary_large_image" />
        <meta name="twitter:url" content={canonicalURL} />
        <meta name="twitter:title" content={ogTitle} />
        <meta name="twitter:description" content={description} />
        <meta name="twitter:image" content={ogImageURL} />

        <!-- Feeds -->
        <link
            rel="alternate"
            type="application/rss+xml"
            title={`${SITE_NAME} RSS`}
            href="/rss.xml"
        />
        <link rel="sitemap" type="application/xml" href="/sitemap-index.xml" />

        <slot name="head" />
    </head>
    <body>
        {previewMode && (
            <div class="preview-banner" role="status">
                <span>Preview — showing unpublished drafts</span>
                <a href={`${Astro.url.pathname}?preview=0`}>exit</a>
            </div>
        )}
        <header>
            <slot name="header">
                <a href="/">home</a>
                <!--
          Header tile is one of the 100 pre-rendered azulejo snapshots
          (worker-og/azulejo, mirrored into public/azulejo) instead of
          the live WebGL AzulejoTile island. The island pulled React +
          three.js (~250KB gz) onto every page for a 32px decorative
          element; a 13KB JPG reads identically at this size. The
          inline script picks a random tile per load to keep the
          per-visit variance; <noscript> pins a fixed tile. The 45°
          rotation turns the square into a diamond.
        -->
                <span class="header-tile">
                    <img
                        id="header-azulejo"
                        width="32"
                        height="32"
                        alt="iammatthias"
                        decoding="async"
                    />
                    <script is:inline>
                        {
                            const n = String(
                                1 + Math.floor(Math.random() * 100),
                            ).padStart(3, "0");
                            document.getElementById("header-azulejo").src =
                                "/azulejo/" + n + ".jpg";
                        }
                    </script>
                    <noscript>
                        <img
                            src="/azulejo/001.jpg"
                            width="32"
                            height="32"
                            alt="iammatthias"
                        />
                    </noscript>
                </span>
                <a href="/menu" data-menu-trigger>menu</a>
            </slot>
        </header>

        <main>
            {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
            <slot />
        </main>

        <footer>
            <slot name="footer">
                <small>© {new Date().getFullYear()} Matthias Jordan</small>
            </slot>
        </footer>

        <!--
      Progressive-enhancement menu. The header's `<a href="/menu">` link
      navigates to /menu when JS is off; the script below intercepts the
      click on any element with `[data-menu-trigger]` and opens this
      <dialog> instead. Native <dialog> handles ESC, focus trap, and
      backdrop scroll lock for free.
    -->
        <dialog id="site-menu" class="site-menu" aria-label="Site navigation">
            <div class="site-menu__inner">
                <button
                    type="button"
                    class="site-menu__close"
                    aria-label="Close menu"
                    data-menu-close>close</button
                >
                <MenuLinks />
            </div>
        </dialog>

        <script>
            const dialog = document.getElementById("site-menu");
            if (dialog instanceof HTMLDialogElement) {
                for (const trigger of document.querySelectorAll(
                    "[data-menu-trigger]",
                )) {
                    trigger.addEventListener("click", (event) => {
                        event.preventDefault();
                        dialog.showModal();
                    });
                }
                for (const closer of dialog.querySelectorAll(
                    "[data-menu-close]",
                )) {
                    closer.addEventListener("click", () => dialog.close());
                }
                // Click on the backdrop (i.e. on the <dialog> element itself,
                // outside its inner content) closes the menu.
                dialog.addEventListener("click", (event) => {
                    if (event.target === dialog) dialog.close();
                });
                // Close after navigation so the menu doesn't linger on back.
                dialog.addEventListener("click", (event) => {
                    const target = event.target;
                    if (target instanceof HTMLAnchorElement) dialog.close();
                });
            }
        </script>

        <script>
            // Image figures carry the blob's dominant colour as an inline
            // background — a load-time placeholder that fills the
            // aspect-ratio box before the bytes arrive. It must be cleared
            // once the image loads, or it shows through transparent PNGs
            // forever. (The homepage arch is a <div>, not a <figure>, so
            // it keeps its frame colour.)
            for (const fig of document.querySelectorAll(
                'figure[style*="background"]',
            )) {
                const img = fig.querySelector("img");
                if (!img) continue;
                const clear = () => {
                    (fig as HTMLElement).style.background = "";
                };
                if (img.complete) clear();
                else img.addEventListener("load", clear, { once: true });
            }
        </script>
    </body>
</html>

<style>
    body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: var(--pad);
        gap: var(--gap);
    }

    /* Dev-only draft-preview banner. Sticky at the top so it stays
       visible while scrolling — a constant reminder the site is
       showing unpublished content. Never rendered in production. */
    .preview-banner {
        position: sticky;
        top: 0;
        z-index: 20;
        width: 100%;
        max-width: var(--content-max);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius);
        background: var(--color-fg);
        color: var(--color-bg);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.02em;
    }

    .preview-banner a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 0.15em;
        font-weight: var(--fw-medium);
    }

    header,
    footer {
        flex: 0 0 auto;
        width: 100%;
        max-width: var(--content-max);
    }

    /*
   * Header lays out as three equal-flex columns so the middle child is
   * centered relative to the viewport regardless of the side children's
   * widths. (`justify-content: space-between` would only center the
   * middle child when the side children are equal width.)
   */
    header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: var(--space-4);
    }

    /* :global() — slot children come from the page and don't carry the
     layout's scope hash, so unscoped selectors are needed to target them. */
    header > :global(:first-child) {
        justify-self: start;
    }

    header > :global(:last-child) {
        justify-self: end;
    }

    /* Header tile slot — fixed footprint + placeholder. The slot is 32×32
     in layout flow regardless of image load state, so the header doesn't
     reflow while the tile fetches. The rotation makes the tile read as a
     diamond.

     Background uses the warm beige border token rather than --color-fg,
     so the placeholder reads as a gentle diamond hint instead of
     flashing solid near-black before the image paints. */
    .header-tile {
        display: inline-block;
        width: 32px;
        height: 32px;
        background: var(--color-border);
        transform: rotate(45deg);
        transform-origin: center;
        overflow: hidden;
    }

    .header-tile img {
        display: block;
        width: 100%;
        height: 100%;
        object-fit: cover;
    }

    main {
        /* fills space between header and footer; content sits near the top */
        flex: 1 0 auto;
        width: 100%;
        max-width: var(--content-max);
        display: flex;
        flex-direction: column;
    }

    /* `main` owns the vertical rhythm between page sections via the
       adjacent-sibling combinator (inconsistent gaps keyed on section
       type), so no section emits its own outer margin. Default is the
       generous section gap; the page header sits a touch closer to its
       content, and breadcrumbs hug the heading they precede.
       `:global()` because slot content carries the page's scope hash,
       not the layout's. */
    main > :global(* + *) {
        margin-top: var(--space-8);
    }
    main > :global(.page-header + *) {
        margin-top: var(--space-7);
    }
    main > :global(.breadcrumbs + *) {
        margin-top: var(--space-5);
    }

    /* ---------- site menu dialog ---------- */

    .site-menu {
        /* Native <dialog> centers itself on the viewport by default; we
       style only the chrome. Backdrop scroll-lock is automatic. */
        border: none;
        padding: 0;
        background: var(--color-bg);
        color: var(--color-fg);
        width: min(420px, calc(100% - var(--pad) * 2));
        max-height: calc(100dvh - var(--pad) * 2);
        border-radius: var(--radius);
        /* Subtle warmth — doesn't read as a heavy modal */
        box-shadow:
            0 1px 0 var(--color-border),
            0 24px 64px -12px rgba(0, 0, 0, 0.25);
    }

    .site-menu::backdrop {
        background: rgba(0, 0, 0, 0.4);
        backdrop-filter: blur(2px);
    }

    .site-menu__inner {
        padding: var(--space-6);
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
    }

    .site-menu__close {
        align-self: flex-end;
        background: none;
        border: 0;
        padding: 0;
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-sm);
        color: var(--color-muted);
        cursor: pointer;
    }

    .site-menu__close:hover {
        color: var(--color-fg);
        text-decoration: underline;
    }
</style>
