---
import BaseLayout from "@layouts/BaseLayout.astro";
---

<BaseLayout title="Not found" description="That page doesn't exist." noindex>
    <article class="not-found">
        <p class="kind">404</p>
        <h1>Not found</h1>
        <p>That page doesn't exist — or it moved during the redesign.</p>
        <!-- Only evergreen routes here — publication slugs are dynamic
             (they come from Farfield), so linking them from a static
             404 would silently rot if collections change. -->
        <p>
            Try the <a href="/">homepage</a>, browse
            <a href="/content">all content</a> or the <a href="/feed">feed</a>,
            or wander the <a href="/tags">tag index</a>.
        </p>
    </article>
</BaseLayout>

<style>
    .not-found {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        max-width: 60ch;
    }

    .kind {
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-muted);
    }

    .not-found h1 {
        font-family: var(--font-serif);
    }

    .not-found p {
        line-height: var(--lh-relaxed);
        text-wrap: pretty;
    }
</style>
