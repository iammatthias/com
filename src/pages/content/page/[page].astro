---
// All-content index, pages 2+. Page 1 is /content (content/index.astro).
// Both render through ContentIndex.astro.
export const prerender = false;

import ContentIndex from "../../../components/ContentIndex.astro";
import { getLiveCollection } from "astro:content";
import {
    setResponseCacheHeaders,
    deepPageCacheOptions,
} from "../../../lib/cache";
import { getPage, parsePageSegment } from "../../../lib/pagination";
import type {
    DocumentData,
    PublicationData,
} from "../../../lib/farfield-loader";

const page = parsePageSegment(Astro.params.page);
if (page === null) return new Response(null, { status: 404 });

let items: DocumentData[] = [];
let pubs: PublicationData[] = [];

const [docsResult, pubsResult] = await Promise.all([
    getLiveCollection("documents"),
    getLiveCollection("publications"),
]);
if (docsResult.error) {
    console.error(
        "[/content] Farfield documents fetch failed:",
        docsResult.error,
    );
} else {
    items = docsResult.entries.map((e) => e.data);
}
if (pubsResult.error) {
    console.error(
        "[/content] Farfield publications fetch failed:",
        pubsResult.error,
    );
} else {
    pubs = pubsResult.entries.map((e) => e.data);
}

const paged = getPage(items, page, "/content");
if (!paged) return new Response(null, { status: 404 });

setResponseCacheHeaders(Astro.response, docsResult.cacheHint, {
    ...deepPageCacheOptions(page),
    extraTags: pubsResult.cacheHint?.tags,
});
---

<ContentIndex paged={paged} pubs={pubs} />
