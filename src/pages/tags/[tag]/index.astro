---
export const prerender = false;

import BaseLayout from "../../../layouts/BaseLayout.astro";
import FeedCard from "../../../components/FeedCard.astro";
import { getLiveCollection } from "astro:content";
import { setResponseCacheHeaders } from "../../../lib/cache";
import type { DocumentData } from "../../../lib/farfield-loader";

const tag = Astro.params.tag;
if (!tag) {
    return Astro.redirect("/tags");
}

let items: DocumentData[] = [];
const {
    entries,
    error,
    cacheHint,
} = await getLiveCollection("documents", { tag });
if (error) {
    console.error(`[/tags/${tag}] Farfield fetch failed:`, error);
} else {
    items = entries.map((e) => e.data);
}
const count = items.length;

if (count === 0 && !error) {
    // No entries with this tag — the tag itself doesn't exist on any
    // current document. Rewrite to the tag index rather than serve an
    // empty page (also bypasses caching of a not-really-here URL).
    return Astro.rewrite("/tags");
}

setResponseCacheHeaders(Astro.response, cacheHint);
---

<BaseLayout
    title={`#${tag}`}
    description={`Entries tagged ${tag} — iammatthias.`}
    breadcrumbs={[
        { label: "tags", href: "/tags" },
        { label: tag },
    ]}
>
    <header class="page-header">
        <h1>{tag}</h1>
        <p class="meta">
            <a href={`/tags/${encodeURIComponent(tag)}/rss.xml`}>RSS</a>
            <span aria-hidden="true"> · </span>
            <span>{count} {count === 1 ? "entry" : "entries"}</span>
        </p>
    </header>

    <ul class="feed-grid">
        {items.map((item) => (
            <FeedCard
                href={item.href}
                title={item.title}
                description={item.description}
                publishedAt={item.publishedAt}
                kind={item.publication.name.toLowerCase()}
            />
        ))}
    </ul>
</BaseLayout>
