---
import BaseLayout from "@layouts/BaseLayout.astro";
import MenuLinks from "@components/MenuLinks.astro";
---

<BaseLayout title="Menu" description="Site navigation." ogImage="/menu" noindex>
    <article class="menu-page">
        <header>
            <h1>Menu</h1>
        </header>
        <MenuLinks />
    </article>
</BaseLayout>

<style>
    .menu-page {
        display: flex;
        flex-direction: column;
        gap: var(--space-7);
        max-width: 60ch;
    }

    .menu-page header h1 {
        font-family: var(--font-serif);
    }
</style>
