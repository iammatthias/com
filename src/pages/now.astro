---
// SSR — feed entries pulled live from Farfield so new updates appear
// without a rebuild. Cache-Control is set below from the loader's hint.
export const prerender = false;

import BaseLayout from "@layouts/BaseLayout.astro";
import FeedEntryCard from "@components/FeedEntryCard.astro";
import { getLiveCollection } from "astro:content";
import { setResponseCacheHeaders } from "@lib/cache";
import {
    entriesOf,
    resolveBodyMedia,
    type FeedEntryData,
    type ResolvedMedia,
} from "@lib/farfield-loader";
import type { MenuMeta } from "@lib/menu";
import { SOCIAL_LINKS } from "@lib/identity";

export const menu: MenuMeta = { group: "personal", order: 1 };

const {
    entries: rawEntries,
    error: feedError,
    cacheHint,
} = await getLiveCollection("feedEntries");
if (feedError) {
    console.error("[/now] Farfield feed entries fetch failed:", feedError);
}
// "Recent updates" is a teaser — cap it to the latest few; the full,
// infinitely-scrolling list lives at /feed ("see all →" below).
const RECENT_LIMIT = 5;
const feedItems: FeedEntryData[] = entriesOf<FeedEntryData>(rawEntries).slice(
    0,
    RECENT_LIMIT,
);

setResponseCacheHeaders(Astro.response, cacheHint);

// Resolve each (capped) entry's body to a flat media list at render time.
const mediaByRkey = new Map<string, ResolvedMedia[]>(
    await Promise.all(
        feedItems.map(
            async (it) => [it.rkey, await resolveBodyMedia(it.body)] as const,
        ),
    ),
);

// Shared with the JSON-LD Person entity's sameAs (lib/identity.ts) —
// one list drives both the visible "Find me" section and the schema.
const socialLinks = SOCIAL_LINKS.filter((l) => !l.schemaOnly);
---

<BaseLayout
    title="Now"
    description="What I'm working on right now."
    ogImage="/now"
    profilePage
>
    <article class="prose">
        <h1>Now</h1>

        <section class="bio">
            <p>Hi, I am Matthias.</p>
            <p>
                I'm a photographer who builds software. Most of what I build
                is for me, and some of it turns out to be useful for other
                people too.
            </p>
            <p>
                This site is my cozy corner of the web. I want a web that's
                open and personal, so everything here lives on infrastructure
                I run. You can keep up with my career on my{" "}
                <a href="/resume">resume</a>.
            </p>
            <p>
                I live in Southern California. When I'm not at my desk I'm
                usually cooking or out with a camera.
            </p>
        </section>

        <section>
            <h2>Working on</h2>
            <ul>
                <li>Solutions Engineer @ ----------</li>
                <li>
                    Cooking — see <a href="/recipes">recipes</a>
                </li>
                <li>Photographing — see <a href="/art">art</a></li>
            </ul>
        </section>

        <section class="updates">
            <h2>
                Recent updates{" "}
                <a href="/feed" class="see-all">see all →</a>
            </h2>
            {
                feedItems.length === 0 ? (
                    <p class="feed-empty">Nothing recent.</p>
                ) : (
                    <ul class="feed feed--compact">
                        {feedItems.map((item) => (
                            <FeedEntryCard
                                item={item}
                                media={mediaByRkey.get(item.rkey) ?? []}
                            />
                        ))}
                    </ul>
                )
            }
        </section>

        <section>
            <h2>Find me</h2>
            <ul class="links">
                {
                    socialLinks.map((link) => (
                        <li>
                            <a href={link.url}>
                                {link.name}{" "}
                                <span class="username">{link.username}</span>
                            </a>
                        </li>
                    ))
                }
            </ul>
        </section>
    </article>
</BaseLayout>

<style>
    /* `.prose` (column, rhythm, headings) + `.see-all` come from
       globals.css — only page-specific styling lives below. */

    .prose ul {
        list-style: none;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    .prose li {
        font-size: var(--fs-base);
        line-height: var(--lh-relaxed);
    }

    /* Bio paragraphs (merged in from the old /about page). Comfortable
       reading size, slightly relaxed leading. The wrapping section's
       own gap separates the paragraphs from each other. */
    .bio p {
        font-size: var(--fs-base);
        line-height: var(--lh-relaxed);
        text-wrap: pretty;
    }

    .bio p:first-child {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-xl);
    }

    .username {
        color: var(--color-muted);
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-sm);
    }

    /* Compact override for the feed embed: the standalone /feed list
       has roomier spacing; inside this page's section the feed reads
       better with tighter gaps. Targets the global `.feed` / `.feed-item`
       classes from globals.css via `:global(...)`. */
    .updates :global(.feed--compact) {
        gap: var(--space-5);
    }

    .updates :global(.feed--compact .feed-item) {
        gap: var(--space-2);
        padding-top: var(--space-4);
    }
</style>
