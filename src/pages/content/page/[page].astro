---
// All-content index, pages 2+. Page 1 is /content (content/index.astro).
// Both render through ContentIndex.astro, with fetch + error handling
// shared in @lib/content-index.
export const prerender = false;

import ContentIndex from "@components/ContentIndex.astro";
import {
    setResponseCacheHeaders,
    deepPageCacheOptions,
} from "@lib/cache";
import { loadContentIndex } from "@lib/content-index";
import { getPage, parsePageSegment } from "@lib/pagination";
import { isPreview } from "@lib/preview";

const page = parsePageSegment(Astro.params.page);
if (page === null) return new Response(null, { status: 404 });

const preview = isPreview(Astro);
const { items, pubs, cacheHint, extraTags } = await loadContentIndex(preview);

const paged = getPage(items, page, "/content");
if (!paged) return new Response(null, { status: 404 });

setResponseCacheHeaders(Astro.response, cacheHint, {
    ...deepPageCacheOptions(page),
    extraTags,
});
---

<ContentIndex paged={paged} pubs={pubs} />
