---
export const prerender = false;

import BaseLayout from "@layouts/BaseLayout.astro";
import RecordColophon from "@components/RecordColophon.astro";
import FeedCard from "@components/FeedCard.astro";
import Lightbox from "@components/Lightbox.astro";
import { getLiveCollection, getLiveEntry } from "astro:content";
import { LiveEntryNotFoundError } from "astro/content/runtime";
import { entriesOf, type DocumentData } from "@lib/farfield-loader";
import { setResponseCacheHeaders } from "@lib/cache";
import { isPreview } from "@lib/preview";
import { fmtDateLong as fmtDate, hashSeed } from "@lib/format";
import { renderMarkdownBody, readingTime, buildToc } from "@lib/doc-render";

const publicationSlug = Astro.params.publication;
const docSlug = Astro.params.slug;
if (!publicationSlug || !docSlug) {
    return new Response(null, { status: 404 });
}

const preview = isPreview(Astro);

const { entry, error, cacheHint } = await getLiveEntry("documents", {
    publication: publicationSlug,
    slug: docSlug,
    preview,
});
if (error) {
    // Astro wraps "no such entry" as `LiveEntryNotFoundError` rather
    // than returning `entry === undefined`, so we have to discriminate
    // here. Unknown errors are upstream failures → 502; missing
    // records (slug typos, deleted docs, stale links) → 404.
    if (LiveEntryNotFoundError.is(error)) {
        return new Response(null, { status: 404 });
    }
    console.error(
        `[/${publicationSlug}/${docSlug}] Farfield fetch failed:`,
        error,
    );
    return new Response(null, { status: 502 });
}
if (!entry) {
    return new Response(null, { status: 404 });
}
const item: DocumentData = entry.data;

setResponseCacheHeaders(Astro.response, cacheHint);

// Content is a single markdown body with inline `blob://` / `series://`
// embeds. `renderMarkdownBody` resolves each one and stitches in the
// final HTML.
const bodyHtml = item.body ? await renderMarkdownBody(item.body) : "";

const reading = readingTime(item.body);

// Always build the TOC so we can decide based on actual heading count
// (not a word-count proxy). Bodies with fewer than two headings drop
// the navigation chrome — there's nothing to navigate.
const { html: bodyWithIds, entries: tocEntries } = buildToc(bodyHtml);
// Art docs lean on full-width masonry series for `## Section` headings;
// the desktop TOC sidebar narrows the body column and squeezes those
// galleries into 2-up instead of 3-up. Skip the sidebar for that
// publication — the prose is short enough that navigation by scroll
// is fine, and the masonry gets the room it needs.
const TOC_DISABLED_PUBLICATIONS = new Set(["art"]);
const showToc =
    tocEntries.length >= 2 &&
    !TOC_DISABLED_PUBLICATIONS.has(item.publication.slug);

// Stable seed for the colophon's terrazzo banner — same record key →
// same pattern, forever.
const bannerSeed = hashSeed(`${item.collection}/${item.rkey}`);

// Farfield's record-viewer URL — points at the JSON record on the
// content service so curious readers can see the raw data behind a
// post. The new API takes just the slug (rkey); collection is implied.
const recordUrl = `https://content.farfield.systems/api/entries/${encodeURIComponent(item.rkey)}`;

// Related reading: score every other document by shared-tag count, then
// recency, and take the top few. The documents collection is already
// warm in the per-isolate cache (MenuLinks fetches it on every page), so
// this adds no real upstream cost. With no shared tags the score is
// uniformly zero and it falls back to the most recent other posts.
const RELATED_COUNT = 6;
let related: DocumentData[] = [];
{
    const { entries: allDocs, error: relErr } =
        await getLiveCollection("documents", { preview });
    if (relErr) {
        console.error(
            `[/${publicationSlug}/${docSlug}] related-docs fetch failed:`,
            relErr,
        );
    } else {
        const sharedTags = (tags: string[]) =>
            tags.filter((t) => item.tags.includes(t)).length;
        related = entriesOf<DocumentData>(allDocs)
            .filter(
                (d) =>
                    !(
                        d.collection === item.collection &&
                        d.rkey === item.rkey
                    ),
            )
            .sort(
                (a, b) =>
                    sharedTags(b.tags) - sharedTags(a.tags) ||
                    b.publishedAt.localeCompare(a.publishedAt),
            )
            .slice(0, RELATED_COUNT);
    }
}
---

<BaseLayout
    title={item.title}
    description={item.description}
    ogImage={`/${item.publication.slug}/${encodeURIComponent(item.title)}`}
    ogType="article"
    article={{
        publishedTime: item.publishedAt,
        modifiedTime: item.updatedAt,
    }}
    breadcrumbs={[
        {
            label: item.publication.name.toLowerCase(),
            href: `/${item.publication.slug}`,
        },
    ]}
>
    <article class="doc">
        <header class="doc-hero">
            {item.published === false && (
                <p class="doc-draft">Draft — unpublished</p>
            )}
            <h1>{item.title}</h1>
            <p class="dateline">
                <time datetime={item.publishedAt}>{fmtDate(item.publishedAt)}</time>
                {reading.minutes > 0 && (
                    <>
                        <span aria-hidden="true"> · </span>
                        <span>{reading.minutes} min read</span>
                    </>
                )}
            </p>
        </header>

        {showToc && (
            <details class="doc-toc">
                <summary class="doc-toc__summary">
                    <span class="doc-toc__label">On this page</span>
                    <span class="doc-toc__count" aria-hidden="true">
                        {tocEntries.length} sections
                    </span>
                </summary>
                <ul>
                    {tocEntries.map((entry) => (
                        <li class:list={[`toc-level-${entry.level}`]}>
                            <a href={`#${entry.id}`}>{entry.text}</a>
                        </li>
                    ))}
                </ul>
            </details>
        )}

        <div class="doc-body" set:html={bodyWithIds} />

        {item.tags.length > 0 && (
            <footer class="doc-tags">
                <span class="tags-label">tagged</span>
                <ul>
                    {item.tags.map((t) => (
                        <li>
                            <a href={`/tags/${encodeURIComponent(t)}`}>{t}</a>
                        </li>
                    ))}
                </ul>
            </footer>
        )}

        {related.length > 0 && (
            <section class="doc-related" aria-label="Related posts">
                <h2>Related</h2>
                <ul class="feed-grid">
                    {related.map((r) => (
                        <FeedCard
                            href={r.href}
                            title={r.title}
                            description={r.description}
                            publishedAt={r.publishedAt}
                            kind={r.publication.name.toLowerCase()}
                        />
                    ))}
                </ul>
            </section>
        )}

        <!--
          Colophon: a thin terrazzo banner alongside the metadata block.
          Banner seed is FNV-hashed from the record key so the tile
          pattern is permanent for that document. The metadata block
          surfaces collection / rkey / cid / timestamps, with the record
          URL linking back to the raw Farfield JSON.
        -->
        <RecordColophon
            seed={bannerSeed}
            fields={[
                { label: "collection", value: item.collection },
                { label: "rkey", value: item.rkey },
                { label: "record cid", value: item.cid },
                { label: "record", value: recordUrl, href: recordUrl },
                {
                    label: "created",
                    value: item.publishedAt,
                    datetime: item.publishedAt,
                },
                {
                    label: "updated",
                    value: item.updatedAt,
                    datetime: item.updatedAt,
                },
            ]}
        />
    </article>

    <Lightbox />

    <!-- Render any ```mermaid code blocks the body carries into diagrams.
         The module lazy-imports mermaid, so the library only downloads on
         pages that actually contain one. -->
    <script>
        import { renderMermaid } from "@lib/mermaid-client";
        void renderMermaid();
    </script>
</BaseLayout>

<style>
    /* The article-level gap is the rhythm that separates hero, body,
       tags, and colophon. Each section uses its own internal gap for
       finer-grained spacing. */
    article {
        display: flex;
        flex-direction: column;
        gap: var(--space-7);
    }

    /* Reworked hero: serif italic title leads, dateline sits right
       under it as a small italic line. The article's gap separates the
       hero from the content blocks — no margin-bottom needed here. */
    .doc-hero {
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
    }

    /* Draft marker on the article hero — only reachable in dev preview
       mode, where it flags that this record isn't published yet. */
    .doc-draft {
        align-self: flex-start;
        padding: 0.15em 0.6em;
        border-radius: 999px;
        background: var(--color-fg);
        color: var(--color-bg);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.03em;
    }

    .doc-hero h1 {
        font-family: var(--font-serif);
        font-style: italic;
        font-weight: var(--fw-normal);
        font-size: clamp(var(--fs-3xl), 6vw, var(--fs-4xl));
        line-height: 1.05;
        letter-spacing: -0.015em;
        text-wrap: balance;
    }

    .dateline {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-sm);
        color: var(--color-muted);
    }

    .doc-body {
        display: flex;
        flex-direction: column;
        font-size: var(--fs-base);
        line-height: var(--lh-relaxed);
    }

    /* Prose rhythm owned by the container via the adjacent-sibling
       combinator (inconsistent gaps): a default between blocks, with
       more room leading into section headings. No block carries its own
       margin, so embeds (figures, triptychs, galleries) stay
       self-contained and never double up. */
    .doc-body > :global(* + *) {
        margin-top: var(--space-5);
    }
    .doc-body > :global(* + h2) {
        margin-top: var(--space-7);
    }
    .doc-body > :global(* + h3) {
        margin-top: var(--space-6);
    }

    /* Doc-specific heading typography. Tables, lists, code, blockquote,
       hr, etc. are handled in globals.css — no per-page overrides for
       those. The :global(...) selectors here target the markdown
       renderer's output (which doesn't carry the layout's scope hash). */
    .doc-body :global(h2) {
        font-family: var(--font-serif);
        font-size: var(--fs-2xl);
    }

    .doc-body :global(h3) {
        font-family: var(--font-serif);
        font-size: var(--fs-xl);
    }

    /* Tighten list internals when they appear in a flex-gap container,
       since `gap` already handles between-item spacing at the prose
       level. */
    .doc-body :global(ul),
    .doc-body :global(ol) {
        display: flex;
        flex-direction: column;
        gap: var(--space-2);
    }

    /* Markdown-embedded inline images should fill the reading column
       crisply; the rounded radius matches our other media. */
    .doc-body :global(img) {
        display: block;
        width: 100%;
        height: auto;
        border-radius: var(--radius);
    }

    /* TOC is a native <details> sitting inline near the top of the
       article — same on every viewport. No grid columns; body stays
       full-width. Sticky so the summary follows the reader down the
       page; opening the panel expands the list in place. Background
       + z-index keep it readable when content scrolls behind. */
    .doc-toc {
        font-size: var(--fs-sm);
        line-height: var(--lh-relaxed);
        padding: var(--space-3) 0;
        border-top: 1px solid var(--color-border);
        border-bottom: 1px solid var(--color-border);
        position: sticky;
        top: 0;
        z-index: 5;
        background: var(--color-bg);
    }

    /* Bound the open list so a 30-entry TOC doesn't cover the whole
       viewport — readers can scroll inside the panel instead. */
    .doc-toc ul {
        max-height: calc(100dvh - 6rem);
        overflow-y: auto;
    }

    .doc-toc__summary {
        display: flex;
        align-items: center;
        justify-content: space-between;
        gap: var(--space-3);
        cursor: pointer;
        user-select: none;
        list-style: none;
    }

    /* Hide the native disclosure marker — chevron pseudo below
       matches the typographic style of the site. */
    .doc-toc__summary::-webkit-details-marker {
        display: none;
    }

    .doc-toc__summary::after {
        content: "";
        width: 0.5em;
        height: 0.5em;
        border-right: 1px solid currentColor;
        border-bottom: 1px solid currentColor;
        transform: rotate(45deg) translate(-25%, -25%);
        color: var(--color-muted);
        transition: transform 150ms var(--ease);
    }

    .doc-toc[open] .doc-toc__summary::after {
        transform: rotate(-135deg) translate(-25%, -25%);
    }

    .doc-toc__label {
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-muted);
        font-size: var(--fs-sm);
    }

    .doc-toc__count {
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        color: var(--color-muted);
        margin-right: auto;
        margin-left: var(--space-3);
    }

    .doc-toc ul {
        list-style: none;
        margin: var(--space-3) 0 0;
        padding: 0;
        display: flex;
        flex-direction: column;
        gap: 0.35em;
    }

    .doc-toc li {
        list-style: none;
    }

    .doc-toc .toc-level-3 {
        padding-left: var(--space-3);
        font-size: var(--fs-xs);
    }

    .doc-toc a {
        color: var(--color-muted);
        text-decoration: none;
        text-wrap: balance;
    }

    .doc-toc a:hover {
        color: var(--color-fg);
        text-decoration: underline;
        text-underline-offset: 0.15em;
    }

    /* `.doc-figure` and the masonry tiles below come from `set:html`,
       so they don't carry the layout's scope hash — target them via
       `:global(...)` to ensure styles land. */
    .doc-body :global(.doc-figure) {
        /* No vertical margin — the prose rhythm owns the gap (a class-
           level `margin` here would out-specify it). */
        overflow: hidden;
        border-radius: var(--radius);
    }

    .doc-body :global(.doc-figure img) {
        display: block;
        width: 100%;
        height: auto;
    }

    /* mermaid diagrams are injected client-side (see mermaid-client.ts)
       in place of the raw code block, so — like the figures above — they
       arrive without the scope hash and need `:global`. The SVG is pinned
       to its native size in JS (so labels never shrink to mush on a
       phone); this scrolls it horizontally like a wide code block when it
       outgrows the column. `safe center` centers it when it fits but
       falls back to start-aligned when it overflows, so the left edge
       stays reachable by scroll instead of being clipped. */
    .doc-body :global(.mermaid-figure) {
        margin: 0;
        display: flex;
        justify-content: safe center;
        overflow-x: auto;
        -webkit-overflow-scrolling: touch;
    }

    .doc-body :global(.mermaid-figure svg) {
        height: auto;
    }

    /* Series gallery — CSS multi-column gives a true waterfall masonry
       layout across all evergreens (Safari's native `grid-template-rows:
       masonry` is still spec-experimental). Tiles use `break-inside:
       avoid` so each figure stays whole inside its column. Columns step
       down at narrower breakpoints so tiles never get too cramped. */
    .doc-body :global(.series-grid) {
        column-count: 3;
        column-gap: var(--space-3);
    }

    @media (max-width: 768px) {
        .doc-body :global(.series-grid) {
            column-count: 2;
        }
    }

    @media (max-width: 480px) {
        .doc-body :global(.series-grid) {
            column-count: 1;
        }
    }

    .doc-body :global(.series-tile) {
        margin: 0 0 var(--space-3);
        overflow: hidden;
        border-radius: var(--radius);
        break-inside: avoid;
    }

    .doc-body :global(.series-tile img) {
        display: block;
        width: 100%;
        height: auto;
    }

    /* Triptych — a diptych pair with the verse as a shared caption.
       The two images sit side by side as a related pair; the verse
       (serif) and capture note (mono) read beneath as commentary on
       them. Centered, constrained plate. Comes through `set:html`, so
       target via :global. */
    .doc-body :global(.triptych) {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
        max-width: 46rem;
        /* Horizontal centering only — never set a vertical margin here,
           or it out-specifies the prose container's rhythm and the
           triptych jams against its neighbour. */
        margin-inline: auto;
    }

    /* The image pair — two equal columns. */
    .doc-body :global(.triptych__pair) {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: var(--space-4);
    }

    .doc-body :global(.triptych__img .series-tile) {
        margin: 0;
    }

    /* Caption block beneath the pair: verse + note, centered. */
    .doc-body :global(.triptych__text) {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-3);
        text-align: center;
    }

    /* The verse — serif italic, the lyrical voice of the piece. */
    .doc-body :global(.triptych__text p) {
        margin: 0;
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-lg);
        line-height: var(--lh-relaxed);
        text-wrap: balance;
        color: var(--color-fg);
    }

    /* The capture note — mono + muted, clearly metadata rather than
       another line of verse. */
    .doc-body :global(.triptych__text .stanza-note) {
        margin: 0;
        font-family: var(--font-mono);
        font-style: normal;
        font-size: var(--fs-xs);
        letter-spacing: 0.02em;
        line-height: var(--lh-normal);
        color: var(--color-muted);
        text-wrap: pretty;
    }

    /* Optional trailing caption block (rare — most notes live inline). */
    .doc-body :global(.triptych__caption) {
        text-align: center;
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        color: var(--color-muted);
    }

    .doc-body :global(.triptych-loose) {
        text-align: center;
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-muted);
    }

    /* Each clickable image lives inside a transparent <button> so the
       click target is a real focusable control (keyboard + screen
       readers get the affordance), with no visible chrome. Cursor
       gives a zoom-in hint on hover, mirroring the modal action. */
    .doc-body :global(.zoom-btn) {
        display: block;
        width: 100%;
        padding: 0;
        margin: 0;
        border: 0;
        background: transparent;
        cursor: zoom-in;
        color: inherit;
        font: inherit;
    }

    .doc-body :global(.zoom-btn:focus-visible) {
        outline: 2px solid var(--color-accent);
        outline-offset: 2px;
    }

    .doc-tags {
        display: flex;
        flex-wrap: wrap;
        align-items: baseline;
        gap: var(--space-3);
        padding-top: var(--space-5);
        border-top: 1px solid var(--color-border);
        font-size: var(--fs-sm);
    }

    .tags-label {
        font-family: var(--font-serif);
        font-style: italic;
        color: var(--color-muted);
    }

    .doc-tags ul {
        list-style: none;
        padding: 0;
        margin: 0;
        display: flex;
        flex-wrap: wrap;
        gap: var(--space-2);
    }

    .doc-tags li {
        list-style: none;
    }

    .doc-tags a {
        color: var(--color-muted);
        text-decoration-thickness: 1px;
    }

    .doc-tags a:hover {
        color: var(--color-fg);
    }

    /* Related posts grid under the article. Reuses the shared
       `.feed-grid` / `.card` primitives from globals.css; only the
       section heading and its top divider are local. */
    .doc-related {
        display: flex;
        flex-direction: column;
        gap: var(--space-5);
        padding-top: var(--space-6);
        border-top: 1px solid var(--color-border);
    }

    .doc-related h2 {
        font-family: var(--font-serif);
        font-style: italic;
        font-weight: var(--fw-normal);
        font-size: var(--fs-xl);
        color: var(--color-muted);
    }
</style>
