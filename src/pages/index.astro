---
// SSR — homepage feed pulls from the Farfield live collection so new
// posts appear without a rebuild. Underlying Farfield fetches are TTL-
// cached per-isolate; the response carries Cache-Control so Cloudflare
// edge-caches the rendered HTML for 60s with stale-while-revalidate.
export const prerender = false;

import BaseLayout from "@layouts/BaseLayout.astro";
import FeedCard from "@components/FeedCard.astro";
import GlassArch from "@components/GlassArch.astro";
import { getLiveCollection } from "astro:content";
import { setResponseCacheHeaders } from "@lib/cache";
import { entriesOf, type DocumentData } from "@lib/farfield-loader";
import { isPreview } from "@lib/preview";

const preview = isPreview(Astro);

// Glass is fetched on the client — GlassArch's script hits
// /api/glass-pick.json after first paint and injects the photo +
// caption. Keeps Glass's latency out of the server TTFB entirely.
const {
    entries: feedEntries,
    error: feedError,
    cacheHint,
} = await getLiveCollection("documents", { preview });

let feed: DocumentData[] = [];
if (feedError) {
    console.error("[index] Farfield feed fetch failed:", feedError);
} else {
    feed = entriesOf<DocumentData>(feedEntries);
}

// The homepage feed is a teaser for the latest work — cap it and point
// at the paginated /content index for the full archive.
const RECENT_LIMIT = 12;
const recent = feed.slice(0, RECENT_LIMIT);

// Translate the loader's cacheHint into HTTP cache headers. See
// lib/cache.ts for the actual policy (s-maxage=60, swr=300) — one
// helper so we don't drift across pages.
setResponseCacheHeaders(Astro.response, cacheHint);
---

<BaseLayout>
    <!--
      `cover` is the above-fold opener: arch + figcaption + intro copy
      share one viewport-height container. The arch takes whatever
      vertical space the intro doesn't need; the intro takes its
      content height. Both fit before the reader has to scroll. The
      feed lives below as a separate section.
    -->
    <section class="cover">
        <GlassArch />

        <section class="intro" aria-label="Introduction">
            <p class="greeting">Hi, I am Matthias.</p>
            <p>
                This is my cozy corner on the web. A collection of
                photographs, projects, recipes, and notes.
            </p>
        </section>
    </section>

    <section class="recent" aria-labelledby="feed-heading">
        <h2 id="feed-heading">
            Recent <a href="/content" class="see-all">see all →</a>
        </h2>
        {
            recent.length === 0 ? (
                <p class="feed-empty">No entries to show right now.</p>
            ) : (
                <ul class="feed-grid">
                    {recent.map((item) => (
                        <FeedCard
                            href={item.href}
                            title={item.title}
                            description={item.description}
                            publishedAt={item.publishedAt}
                            kind={item.publication.name.toLowerCase()}
                            draft={item.published === false}
                        />
                    ))}
                </ul>
            )
        }
    </section>

</BaseLayout>

<style>
    /*
     * `.cover` groups the hero and the intro. Sizing is no longer
     * locked to a viewport-fitting height — the arch frame is pinned
     * to a vh-derived height so the arch reads at a consistent size
     * across photos, and the caption is allowed to flow underneath at
     * its natural length (it may extend past the fold on shorter
     * viewports, which is fine).
     */
    .cover {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: var(--space-5);
        width: 100%;
    }

    /* Personal intro that sits between the arch and the feed. The
       greeting reads as a serif-italic lead; the bio paragraph follows
       at body size, comfortably wide. Both are centered as a column
       within the content max-width but left-aligned internally for
       readable line lengths. */
    .intro {
        flex: 0 0 auto;
        display: flex;
        flex-direction: column;
        gap: var(--space-3);
        width: 100%;
        max-width: 60ch;
    }

    .intro .greeting {
        font-family: var(--font-serif);
        font-style: italic;
        font-size: var(--fs-2xl);
        line-height: var(--lh-tight);
    }

    .intro p {
        font-size: var(--fs-base);
        line-height: var(--lh-relaxed);
        text-wrap: pretty;
    }

    /* ---------- recent feed (below the fold) ---------- */
    /* Named `.recent` (not `.feed`) so it can't collide with the global
       `.feed` list primitive in globals.css. */

    .recent {
        /* The gap from the hero above is owned by `main` (default
           `main > * + *`) — this section emits no outer margin. */
        display: flex;
        flex-direction: column;
        gap: var(--space-6);
        width: 100%;
    }

    .recent h2 {
        font-family: var(--font-serif);
        font-style: italic;
        font-weight: var(--fw-normal);
    }

    /* `.feed-grid` / `.card*` / `.feed-empty` / `.see-all` live in
       globals.css because every list surface (homepage, content,
       publication indexes, tag pages) needs the same primitive. */
</style>
