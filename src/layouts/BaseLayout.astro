---
import "@styles/globals.css";
import SiteMenu from "@components/SiteMenu.astro";
import HeaderTile from "@components/HeaderTile.astro";
import Schema from "@components/Schema.astro";
import Breadcrumbs, {
    type BreadcrumbItem,
} from "@components/Breadcrumbs.astro";
import { isPreview } from "@lib/preview";
import { Font } from "astro:assets";

interface Props {
    /** Page-specific title. Site name is appended automatically. */
    title?: string;
    /** Page-specific meta description. */
    description?: string;
    /**
     * Path on the og worker (https://og.iammatthias.com). Defaults to "/"
     * which renders the homepage card. Pass an absolute URL to override
     * with an arbitrary image.
     */
    ogImage?: string;
    /** og:type. Default "website"; use "article" for posts. */
    ogType?: "website" | "article";
    /** Override canonical URL. Defaults to current pathname under Astro.site. */
    canonical?: string | URL;
    /** Emit robots: noindex,nofollow (and drop the canonical). */
    noindex?: boolean;
    /**
     * Breadcrumb trail rendered above the main content. Last item should
     * have no `href` (current page). The brand link in the header is the
     * implicit home, so this trail starts at the first sub-section.
     * Also emitted as BreadcrumbList JSON-LD.
     */
    breadcrumbs?: BreadcrumbItem[];
    /**
     * Article timestamps for article-shaped pages (doc detail, feed
     * detail). Emits article:published_time / article:modified_time OG
     * meta and a BlogPosting entity in the JSON-LD graph.
     */
    article?: {
        publishedTime: string;
        modifiedTime?: string;
    };
    /** The page is about the site's author (/now) — its JSON-LD
     *  WebPage becomes a ProfilePage with the Person as mainEntity. */
    profilePage?: boolean;
}

const SITE_NAME = "iammatthias";
const SITE_URL = "https://iammatthias.com";
const DEFAULT_DESCRIPTION =
    "Matthias Jordan's cozy corner of the web. Photographs, projects, recipes, and notes, open and personal.";

const {
    title,
    description = DEFAULT_DESCRIPTION,
    ogImage = "/",
    ogType = "website",
    canonical,
    noindex = false,
    breadcrumbs = [],
    article,
    profilePage = false,
} = Astro.props;

// `siteOrigin` is intentionally derived from `Astro.site` (set in
// astro.config.mjs to https://iammatthias.com), NOT from the request
// host. The site is served on multiple hostnames (iammatthias.com +
// iam.casa) but every emitted URL — rel="canonical", og:url,
// twitter:url, sitemap entries, RSS <link> items — collapses to a
// single canonical origin so search engines and social platforms
// consolidate all authority on iammatthias.com. Don't replace this
// with `Astro.url.origin` or anything host-aware: that would split
// SEO juice across both hostnames.
const siteOrigin = Astro.site?.toString() ?? SITE_URL;
const canonicalURL = canonical
    ? new URL(canonical, siteOrigin)
    : new URL(Astro.url.pathname, siteOrigin);

const isAbsolute = /^https?:\/\//i.test(ogImage);
const ogOrigin = import.meta.env.DEV
    ? "http://localhost:8787"
    : "https://og.iammatthias.com";
const ogImageURL = isAbsolute ? new URL(ogImage) : new URL(ogImage, ogOrigin);

const fullTitle = title ? `${title} — ${SITE_NAME}` : SITE_NAME;
const ogTitle = title ?? SITE_NAME;

// Draft-preview mode (dev only). When on, the whole site shows
// unpublished Farfield drafts; the banner below makes that obvious and
// offers a one-click exit. `isPreview` is always false in production.
//
// Skip it on prerendered routes (resume, menu, 404, …): preview is a
// per-request cookie/query decision that can't apply to a static page,
// and reading `Astro.cookies` there reaches for `Astro.request.headers`,
// which a prerendered page has no access to — Astro logs a warning on
// every render. Static pages never show drafts, so `false` is correct.
const previewMode = Astro.isPrerendered ? false : isPreview(Astro);
---

<!doctype html>
<html lang="en">
    <head>
        <meta charset="utf-8" />
        <meta
            name="viewport"
            content="width=device-width, initial-scale=1, viewport-fit=cover"
        />
        <meta name="generator" content={Astro.generator} />
        <meta name="color-scheme" content="light dark" />
        <!-- Theme color matches the warm cream / warm near-black bg
             tokens in globals.css so the browser chrome blends with
             the page rather than flashing pure white/black at load. -->
        <meta
            name="theme-color"
            content="#f1ebdc"
            media="(prefers-color-scheme: light)"
        />
        <meta
            name="theme-color"
            content="#1c1a16"
            media="(prefers-color-scheme: dark)"
        />

        <title>{fullTitle}</title>
        <meta name="description" content={description} />
        <!-- Indexable pages get explicit snippet directives (let search
             engines show full-size snippets/previews); noindex pages get
             no canonical — the two are contradictory signals. -->
        {noindex ? (
            <meta name="robots" content="noindex,nofollow" />
        ) : (
            <>
                <meta
                    name="robots"
                    content="max-snippet:-1, max-image-preview:large, max-video-preview:-1"
                />
                <link rel="canonical" href={canonicalURL} />
            </>
        )}

        <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

        <!-- Metamorphous is the serif used for all headings. The Font
             component emits the @font-face, defines --font-metamorphous
             (with a metric-adjusted fallback so headings don't shift on
             swap), and preloading the latin subset keeps the first-visit
             swap window short (latin-ext stays lazy via unicode-range,
             same as the old hand-written preload). globals.css maps
             --font-serif onto it. -->
        <Font
            cssVariable="--font-metamorphous"
            preload={[{ subset: "latin" }]}
        />

        <!-- Open Graph. Twitter falls back to og:* for everything except
             the card type, so the old twitter:url/title/description/image
             duplicates are intentionally gone. -->
        <meta property="og:site_name" content={SITE_NAME} />
        <meta property="og:type" content={ogType} />
        <meta property="og:url" content={canonicalURL} />
        <meta property="og:title" content={ogTitle} />
        <meta property="og:description" content={description} />
        <meta property="og:image" content={ogImageURL} />
        <meta property="og:image:width" content="1200" />
        <meta property="og:image:height" content="630" />
        <meta property="og:image:alt" content={ogTitle} />
        {article && (
            <>
                <meta
                    property="article:published_time"
                    content={article.publishedTime}
                />
                {article.modifiedTime && (
                    <meta
                        property="article:modified_time"
                        content={article.modifiedTime}
                    />
                )}
            </>
        )}
        <meta name="twitter:card" content="summary_large_image" />

        <Schema
            siteOrigin={siteOrigin}
            siteName={SITE_NAME}
            canonical={canonicalURL.toString()}
            title={ogTitle}
            description={description}
            image={ogImageURL.toString()}
            breadcrumbs={breadcrumbs}
            article={article}
            profilePage={profilePage}
        />

        <!-- Feeds -->
        <link
            rel="alternate"
            type="application/rss+xml"
            title={`${SITE_NAME} RSS`}
            href="/rss.xml"
        />
        <link rel="sitemap" type="application/xml" href="/sitemap.xml" />

        <slot name="head" />
    </head>
    <body>
        {previewMode && (
            <div class="preview-banner" role="status">
                <span>Preview — showing unpublished drafts</span>
                <a href={`${Astro.url.pathname}?preview=0`}>exit</a>
            </div>
        )}
        <header>
            <slot name="header">
                <a href="/">home</a>
                <HeaderTile />
                <a href="/menu" data-menu-trigger>menu</a>
            </slot>
        </header>

        <main>
            {breadcrumbs.length > 0 && <Breadcrumbs items={breadcrumbs} />}
            <slot />
        </main>

        <footer>
            <slot name="footer">
                <small>© {new Date().getFullYear()} Matthias Jordan</small>
            </slot>
        </footer>

        <SiteMenu />

        <script>
            import "@src/scripts/clear-figure-placeholders";
        </script>
    </body>
</html>

<style>
    body {
        min-height: 100dvh;
        display: flex;
        flex-direction: column;
        align-items: center;
        padding: var(--pad);
        gap: var(--gap);
    }

    /* Dev-only draft-preview banner. Sticky at the top so it stays
       visible while scrolling — a constant reminder the site is
       showing unpublished content. Never rendered in production. */
    .preview-banner {
        position: sticky;
        top: 0;
        z-index: 20;
        width: 100%;
        max-width: var(--content-max);
        display: flex;
        align-items: center;
        justify-content: center;
        gap: var(--space-3);
        padding: var(--space-2) var(--space-3);
        border-radius: var(--radius);
        background: var(--color-fg);
        color: var(--color-bg);
        font-family: var(--font-mono);
        font-size: var(--fs-xs);
        letter-spacing: 0.02em;
    }

    .preview-banner a {
        color: inherit;
        text-decoration: underline;
        text-underline-offset: 0.15em;
        font-weight: var(--fw-medium);
    }

    header,
    footer {
        flex: 0 0 auto;
        width: 100%;
        max-width: var(--content-max);
    }

    /*
   * Header lays out as three equal-flex columns so the middle child is
   * centered relative to the viewport regardless of the side children's
   * widths. (`justify-content: space-between` would only center the
   * middle child when the side children are equal width.)
   */
    header {
        display: grid;
        grid-template-columns: 1fr auto 1fr;
        align-items: center;
        gap: var(--space-4);
    }

    /* :global() — slot children come from the page and don't carry the
     layout's scope hash, so unscoped selectors are needed to target them. */
    header > :global(:first-child) {
        justify-self: start;
    }

    header > :global(:last-child) {
        justify-self: end;
    }

    main {
        /* fills space between header and footer; content sits near the top */
        flex: 1 0 auto;
        width: 100%;
        max-width: var(--content-max);
        display: flex;
        flex-direction: column;
    }

    /* `main` owns the vertical rhythm between page sections via the
       adjacent-sibling combinator (inconsistent gaps keyed on section
       type), so no section emits its own outer margin. Default is the
       generous section gap; the page header sits a touch closer to its
       content, and breadcrumbs hug the heading they precede.
       `:global()` because slot content carries the page's scope hash,
       not the layout's. */
    main > :global(* + *) {
        margin-top: var(--space-8);
    }
    main > :global(.page-header + *) {
        margin-top: var(--space-7);
    }
    main > :global(.breadcrumbs + *) {
        margin-top: var(--space-5);
    }
</style>
